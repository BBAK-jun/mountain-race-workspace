{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}/apps/web/src"
    },
    {
      "name": "API: Wrangler Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
